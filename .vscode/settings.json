{
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.associations": {
        "*.css": "tailwindcss"
    },
    "cSpell.words": [
        "roboto"
    ],
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "workbench.colorCustomizations": {
        "activityBar.background": "#51114A",
        "titleBar.activeBackground": "#721868",
        "titleBar.activeForeground": "#FEFCFE",
        "titleBar.inactiveBackground": "#51114A",
        "titleBar.inactiveForeground": "#FEFCFE",
        "statusBar.background": "#51114A",
        "statusBar.foreground": "#FEFCFE",
        "statusBar.debuggingBackground": "#51114A",
        "statusBar.debuggingForeground": "#FEFCFE",
        "statusBar.noFolderBackground": "#51114A",
        "statusBar.noFolderForeground": "#FEFCFE"
    },
}